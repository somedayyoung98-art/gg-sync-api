{
  "openapi": "3.0.3",
  "info": {
    "title": "Diff Matrix Fixture API",
    "version": "1.0.0"
  },
  "paths": {
    "/items/{id}": {
      "get": {
        "operationId": "getItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Item" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Item": {
        "type": "object",
        "required": ["id", "name", "note"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "note": { "type": "string" }
        }
      }
    }
  }
}
