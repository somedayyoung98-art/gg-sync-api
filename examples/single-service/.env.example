# Copy to .env and adjust (never commit .env)

# Local Koa demo (pnpm server)
OPENAPI_HOST=127.0.0.1
OPENAPI_PORT=3100
# Optional; defaults to http://${OPENAPI_HOST}:${OPENAPI_PORT}
# OPENAPI_SERVER_URL=

# Full OpenAPI document URL for sync-api (path must be /openapi.json or /v3/api-docs)
OPENAPI_URL=http://127.0.0.1:3100/openapi.json

# Remote springdoc (set only in .env, never commit real hosts):
# OPENAPI_URL=https://api.example.com/v3/api-docs

# MSW example (api-sync.config.msw.example.ts)
# API_BASE_URL=http://localhost:3000
