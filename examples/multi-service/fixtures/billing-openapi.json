{
  "openapi": "3.0.3",
  "info": {
    "title": "Billing Service API",
    "version": "1.0.0"
  },
  "paths": {
    "/invoices/{id}": {
      "get": {
        "operationId": "getInvoice",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Invoice" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Invoice": {
        "type": "object",
        "required": ["id", "amountCents"],
        "properties": {
          "id": { "type": "string" },
          "amountCents": { "type": "integer" }
        }
      }
    }
  }
}
